# eval/.env.example — Copy to eval/.env and fill in real values.
#
# --detector openai reads these to configure the OpenAI-compatible
# /chat/completions endpoint (LiteLLM, OpenAI, Anthropic-via-proxy,
# local llama.cpp server, etc.). Anything left blank disables the
# openai detector.

# Required
STMB_BASE_URL=http://10.0.0.100:4000          # no trailing slash
STMB_MODEL=claude-3-5-sonnet-20241022
STMB_API_KEY=sk-...replace-me...

# Optional (defaults shown)
STMB_TEMPERATURE=0                            # 0–2
STMB_TIMEOUT_MS=60000                         # per-window request timeout
STMB_MAX_RETRIES=1                            # JSON-parse retries after first failure
STMB_PROMPT_FILE=eval/prompts/baseline.txt    # Appendix A baseline prompt